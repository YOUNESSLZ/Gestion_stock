{
  "$schema": "https://schema.railpack.com",
  "php": "8.2",
  "build": {
    "commands": {
      "install:composer": "composer install --optimize-autoloader --no-interaction"
    }
  },
  "packages": {
    "apt": ["ca-certificates", "git", "unzip", "zip"]
  },
  "variables": {
    "COMPOSER_ALLOW_SUPERUSER": "1"
  }
}
{
  "$schema": "https://schema.railpack.com",
  "php": "8.2",
  "build": {
    "commands": {
      "install:composer": "composer install --optimize-autoloader --no-interaction",
      "install:npm": "npm ci",
      "build:assets": "npm run build"
    }
  },
  "packages": {
    "apt": ["ca-certificates", "git", "unzip", "zip", "nodejs", "npm"]
  },
  "variables": {
    "COMPOSER_ALLOW_SUPERUSER": "1"
  },
  "deploy": {
    "start": "php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=${PORT}"
  }
}
